FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache tzdata bash

ENV TZ=Asia/Taipei
ENV NODE_ENV=production

COPY package*.json ./
RUN npm install --omit=dev

COPY . .

COPY docker/scheduler-crontab /etc/crontabs/root
RUN chmod +x /app/docker/run-scheduled-daily.sh

CMD ["crond", "-f", "-l", "8"]
