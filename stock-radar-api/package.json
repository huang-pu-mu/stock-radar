{
  "name": "stock-radar-api",
  "version": "1.0.0",
  "description": "台股籌碼雷達 APP API",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "import:twse": "node scripts/importDailyTwse.js",
    "import:tpex": "node scripts/importDailyTpex.js",
    "score": "node scripts/calculateChipScores.js",
    "daily": "node scripts/dailyTwse.js",
    "industries": "node scripts/updateIndustries.js",
    "major-holders:setup": "node scripts/setupMajorHolderStats.js",
    "major-holders:import": "node scripts/importMajorHolders.js",
    "alerts:setup": "node scripts/setupWatchlistAlerts.js",
    "alerts:generate": "node scripts/generateWatchlistAlerts.js",
    "strategy-watchlists:setup": "node scripts/setupStrategyWatchlists.js",
    "strategy-backtests:setup": "node scripts/setupStrategyBacktests.js",
    "strategy-backtests:generate": "node scripts/generateStrategyBacktests.js",
    "v13:check": "node scripts/checkV13.js",
    "v14:check": "node scripts/checkV13.js",
    "strategy-params:setup": "node scripts/setupStrategyParameterPresets.js",
