{
  "name": "stock-radar-api",
  "version": "1.0.0",
  "description": "台股籌碼雷達 APP API",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "import:twse": "node scripts/importDailyTwse.js",
    "import:tpex": "node scripts/importDailyTpex.js",
    "score": "node scripts/calculateChipScores.js",
    "daily": "node scripts/dailyTwse.js",
    "industries": "node scripts/updateIndustries.js",
    "major-holders:setup": "node scripts/setupMajorHolderStats.js",
    "major-holders:import": "node scripts/importMajorHolders.js",
    "official:setup": "node scripts/setupOfficialDataTables.js",
    "official:market": "node scripts/importMarketDailySummaries.js",
    "official:revenue": "node scripts/importMonthlyRevenues.js",
    "official:eps": "node scripts/importQuarterlyEps.js",
    "official:events": "node scripts/importStockCalendarEvents.js",
    "official:etf": "node scripts/syncEtfProfilesFromStocks.js",
    "official:daily": "node scripts/importMarketDailySummaries.js && node scripts/importMonthlyRevenues.js && node scripts/importQuarterlyEps.js && node scripts/syncEtfProfilesFromStocks.js"
  },
  "keywords": [
    "stock",
    "taiwan",
    "radar",
    "mariadb",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mariadb": "^3.4.5",
    "google-auth-library": "^10.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
