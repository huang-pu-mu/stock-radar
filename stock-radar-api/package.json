  "keywords": [
    "stock",
    "taiwan",
    "radar",
    "mariadb",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "mariadb": "^3.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
