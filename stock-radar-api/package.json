    "global-risk:score": "node scripts/generateGlobalRiskScores.js",
    "global-risk:daily": "npm run global-risk:import && npm run global-risk:score",
    "v16:check": "node scripts/checkV16.js",
    "v16:test": "node scripts/runV16Acceptance.js",
    "breakout:setup": "node scripts/setupBreakoutEngineTables.js",
    "breakout:generate": "node scripts/generateBreakoutSignals.js",
    "breakout:daily": "npm run breakout:setup && npm run breakout:generate",
    "v17:check": "node scripts/checkV17.js",
    "v17:test": "node scripts/runV17Acceptance.js",
    "main-force:setup": "node scripts/setupMainForceEngineTables.js",
    "main-force:generate": "node scripts/generateMainForceSignals.js",
    "main-force:daily": "npm run main-force:setup && npm run main-force:generate",
    "v18:check": "node scripts/checkV18.js",
    "v18:test": "node scripts/runV18Acceptance.js",
    "big-holder:setup": "node scripts/setupBigHolderTrendTables.js",
    "big-holder:generate": "node scripts/generateBigHolderTrendSignals.js",
    "big-holder:daily": "npm run big-holder:setup && npm run big-holder:generate",
    "v19:check": "node scripts/checkV19.js",
    "v19:test": "node scripts/runV19Acceptance.js",
    "ai-selection:setup": "node scripts/setupAiSelectionTables.js",
    "ai-selection:generate": "node scripts/generateAiSelectionSignals.js",
    "ai-selection:daily": "npm run ai-selection:setup && npm run ai-selection:generate",
    "v20:check": "node scripts/checkV20.js",
    "v20:test": "node scripts/runV20Acceptance.js",
    "v201:check": "node scripts/checkV20.js",
    "v201:test": "node scripts/runV20Acceptance.js"
