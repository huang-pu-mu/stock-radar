    "official:microstructure:setup": "node scripts/setupMicrostructureTables.js",
    "official:daily": "npm run official:market && npm run official:revenue && npm run official:eps && npm run official:etf && npm run official:events && npm run official:institutional-amounts",
    "market-risk:setup": "node scripts/setupMarketRiskTables.js",
    "market-risk:import": "node scripts/importTaifexDailyMarket.js",
    "market-risk:score": "node scripts/generateMarketRiskScores.js",
    "market-risk:daily": "npm run market-risk:import && npm run market-risk:score",
    "v15:check": "node scripts/checkV15.js",
    "v15:test": "node scripts/runV15Acceptance.js",
